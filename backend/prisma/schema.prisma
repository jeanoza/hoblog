generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int        @id @default(autoincrement())
  email            String     @unique
  name             String
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime   @default(now())
  activities       Activity[]
  categories       Category[]
}

model Category {
  id         Int        @id @default(autoincrement())
  name       String
  userId     Int
  activities Activity[]
  user       User       @relation(fields: [userId], references: [id])

  @@unique([userId, name])
}

model Activity {
  id         Int       @id @default(autoincrement())
  title      String
  note       String?
  date       DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  userId     Int
  categoryId Int
  user       User      @relation(fields: [userId], references: [id])
  category   Category  @relation(fields: [categoryId], references: [id])
  photos     Photo[]
}

model Photo {
  id         Int      @id @default(autoincrement())
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}
