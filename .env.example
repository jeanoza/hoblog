# Docker Compose only. See README.md — Environment files.
# PostgreSQL (db service)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=20003

# App (internal container ports — must match nginx/nginx.conf upstreams)
BACKEND_PORT=20002
FRONTEND_PORT=20001

# Public entrypoint (nginx)
NGINX_HOST_PORT=80
FRONTEND_URL=http://localhost
NEXT_PUBLIC_API_URL=/api
