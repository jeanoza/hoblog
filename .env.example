# Docker Compose only. See README.md — Environment files.
# PostgreSQL (db service)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=20003

# App (internal container ports — must match nginx/nginx.conf upstreams)
BACKEND_PORT=20002
FRONTEND_PORT=20001

# Public entrypoint (nginx)
NGINX_HOST_PORT=80
NGINX_HTTPS_PORT=443
# nginx.http.conf (local) | nginx.conf (HTTPS + Let's Encrypt)
NGINX_CONFIG=nginx.http.conf
FRONTEND_URL=http://localhost
NEXT_PUBLIC_API_URL=/api

# HTTPS (production — scripts/init-letsencrypt.sh)
DOMAIN=hoblog.space
CERTBOT_EMAIL=
# Set to 1 to test with Let's Encrypt staging before going live
CERTBOT_STAGING=0
